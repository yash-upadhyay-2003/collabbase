# Application
APP_NAME=CollabBase API
ENV=development
DEBUG=true
API_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://collabbase:change-this-password@localhost:5432/collabbase

# Security
SECRET_KEY=change-this-to-a-long-random-secret-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
